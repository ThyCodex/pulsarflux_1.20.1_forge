# spawn_ores.mcfunction
# Places all PulsarFlux ore blocks around the player for testing

execute as @p at @s run setblock ~1 ~ ~ pulsarflux:aluminum_ore
execute as @p at @s run setblock ~2 ~ ~ pulsarflux:electrum_ore
execute as @p at @s run setblock ~3 ~ ~ pulsarflux:lead_ore
execute as @p at @s run setblock ~4 ~ ~ pulsarflux:lonsdaleite_ore
execute as @p at @s run setblock ~5 ~ ~ pulsarflux:nickel_ore
execute as @p at @s run setblock ~1 ~1 ~ pulsarflux:platinum_ore
execute as @p at @s run setblock ~2 ~1 ~ pulsarflux:silver_ore
execute as @p at @s run setblock ~3 ~1 ~ pulsarflux:tin_ore
